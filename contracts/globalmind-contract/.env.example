# Copie este arquivo para .env e preencha com seus dados
# NUNCA commite o arquivo .env no git

# Chave privada da sua carteira (só para deploy — use uma carteira dedicada para dev)
PRIVATE_KEY=0x_sua_chave_privada_aqui

# RPC URL da Sepolia (testnet)
# Opções gratuitas: https://rpc.sepolia.org ou crie conta no Alchemy/Infura
SEPOLIA_RPC_URL=https://rpc.sepolia.org
